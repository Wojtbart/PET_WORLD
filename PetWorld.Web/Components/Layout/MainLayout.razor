@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h6" Class="mr-4">PetWorld</MudText>
        <MudButton Href="/chat" Variant="Variant.Text" Style="color:white; font-weight:600">Chat</MudButton>
        <MudButton Href="/historia" Variant="Variant.Text" Style="color:white; font-weight:600">Historia</MudButton>
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
